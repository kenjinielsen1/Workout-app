{
  "name": "progressive-overload",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Workout tracker with ML-driven progressive-overload recommendations. Pounds only; 45 lb bars only.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed:sql": "tsx scripts/generate-seed-sql.ts",
    "seed:validate": "tsx scripts/validate-seeds.ts",
    "feature:spec": "tsx scripts/export-feature-spec.ts",
    "db:check": "node scripts/verify-migrations.mjs",
    "export:training": "tsx scripts/export-training-table.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "pg-query-emscripten": "^5.1.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
