# Copy to .env.local and fill in to run against a real Supabase project.
# With these UNSET, the app runs in demo mode (in-memory store, local fake user).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ML service base URL (e.g. http://localhost:8000). UNSET → recommendations use
# the rule engine only (the permanent fallback); the app works fine without it.
VITE_ML_URL=
